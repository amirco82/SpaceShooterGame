flowchart TD
    A["CollisionManager.checkCollisions()"] --> B["Build player ship bounding box"]
    B --> C["Iterate bullets vs enemies"]
    C --> D{"Bullet intersects enemy?"}
    D -->|yes| E["Enemy.takeDamage() and Bullet.moveStep()"]
    E --> F{"Enemy destroyed?"}
    F -->|yes| G["GameStats.scoreUpdate()"]
    F -->|no| H["Continue checking bullets"]
    D -->|no| H
    B --> I["Iterate enemies vs player"]
    I --> J{"Enemy collides with player?"}
    J -->|yes| K["PlayerShip.modifyHealth(-20)"]
    K --> L["Check player destroyed status"]
    J -->|no| M["Continue checking enemies"]
    B --> N["Iterate bonuses vs player"]
    N --> O{"Bonus collides with player?"}
    O -->|yes| P["BonusItem.applyEffect(player)"]
    P --> Q["BonusItem.consume()"]
    Q --> R["Continue checking bonuses"]
    O -->|no| R
    R --> S["Update UI after collision handling"]
    L --> S
    H --> S
    M --> S
