flowchart TD
    A["Player destroyed or stop event"] --> B["SpaceShooterBackend.stopGame()"]
    B --> C["Set currentState = GAME_OVER"]
    C --> D["Clear entities and reset player position"]
    D --> E["UiPort.updatePlayerShip(400, 400)"]
    E --> F["UiPort.renderFrame(enemies, bullets, bonuses)"]
    F --> G["UiPort.showGameOver(finalScore)"]
    G --> H["HUDView shows game over overlay"]
    H --> I["PeriodicLoop.stopLoop()"]
    I --> J{"Await restart or exit"}
    J -->|restart| K["SpaceShooterBackend.startGame()"]
