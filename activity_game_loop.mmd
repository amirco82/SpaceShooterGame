flowchart TD
    A["Game loop tick"] --> B["Check current game state"]
    B -->|ACTIVE_GAME| C["Spawn enemies and bonuses"]
    C --> D["Update enemy, bullet, and bonus positions"]
    D --> E["CollisionManager.checkCollisions()"]
    E --> F["DifficultyManager.updateDifficulty()"]
    F --> G["GameWorld.removeExpiredObjects()"]
    G --> H["Update game stats and time"]
    H --> I["UiPort.updateScore/updateHealth/renderFrame()"]
    I --> J["Check for player destruction"]
    J -->|destroyed| K["Stop game and show Game Over"]
    J -->|alive| L["Continue next tick"]
    B -->|not active| M["Skip updates until resume"]
